{
  "name": "stream-overlay-suite",
  "version": "1.14.0",
  "description": "StreamONER - Discord RPC & YouTube Chat Overlay",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "start:win": "node scripts/start-win.cjs",
    "dev": "electron .",
    "build:ui": "rollup -c",
    "build:icons": "bash ./scripts/subset-material-font.sh",
    "watch:ui": "rollup -c -w",
    "zip:src": "bash ./scripts/create-src-zip.sh",
    "preview:ui": "node scripts/dev-ui-preview.mjs",
    "inject:oauth": "node scripts/inject-youtube-oauth-config.mjs",
    "inject:oauth:strict": "node scripts/inject-youtube-oauth-config.mjs --strict",
    "test": "node --test tests/**/*.test.js",
    "build": "npm run inject:oauth:strict && rollup -c && electron-builder --win",
    "build:oauth-optional": "npm run inject:oauth && rollup -c && electron-builder --win"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.21",
    "pixi.js": "^8.19.0",
    "qrcode": "^1.5.4",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@material/web": "^2.4.1",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "rollup": "^4.60.4"
  },
  "build": {
    "appId": "com.stream-overlay-suite",
    "productName": "StreamONER",
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "StreamONER"
    },
    "extraResources": [
      {
        "from": "assets/",
        "to": "assets/"
      }
    ]
  },
  "author": "",
  "license": "MIT"
}
